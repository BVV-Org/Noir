# =============================================================================
# Noir Vault — Environment Variables
# -----------------------------------------------------------------------------
# Copy to `.env.local` and fill in. With the Shopify vars BLANK, the app runs
# entirely on the mock data provider (mock parity) — going live is purely an
# env change, never a code change.
#
# The mock provider now includes a working in-memory cart, so the drawer,
# quantity steppers, and line removal all function without credentials. The one
# thing it cannot do is check out: there is no Shopify checkout to redirect to,
# and the drawer says so rather than linking somewhere dead.
# =============================================================================

# --- Shopify Storefront API (leave blank to run on mock data) ----------------
# Setting BOTH of these switches every read and the cart to the live provider.
SHOPIFY_STORE_DOMAIN=            # your-store.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=
SHOPIFY_API_VERSION=2025-01

# HMAC secret from the Shopify webhook subscription. Required by
# POST /api/revalidate, which refuses all webhooks when it is unset.
SHOPIFY_REVALIDATION_SECRET=

# --- Customer Account API (real sign-in for /account) ------------------------
# Set all three (plus NEXT_PUBLIC_SITE_URL below) to switch /account from the
# signed-out shell to the live Shopify OAuth flow (authorization code + PKCE).
# Leave any blank to keep the shell — the wishlist works either way.
#
# Both values come from the Shopify "Headless" sales channel:
#   Admin → Sales channels → Headless → Customer Account API.
#
#   API_URL  = the "Customer Account API endpoint" shown there, e.g.
#              https://shopify.com/100708057402/account/customer/api/2025-01/graphql
#              (the /oauth/authorize, /oauth/token, /logout endpoints are derived
#               from the shop id in this URL — no extra config needed.)
#   CLIENT_ID = the OAuth client id shown there.
#
# Client type (set at the top of the Customer Account API settings):
#   - Public / Web  → leave CLIENT_SECRET blank; the flow uses PKCE.
#   - Confidential  → also set SHOPIFY_CUSTOMER_ACCOUNT_CLIENT_SECRET below.
SHOPIFY_CUSTOMER_ACCOUNT_CLIENT_SECRET=
#
# In the same Headless settings, register these under the app's URIs:
#   Callback URI(s):            ${NEXT_PUBLIC_SITE_URL}/api/auth/callback
#   JavaScript origin(s):       ${NEXT_PUBLIC_SITE_URL}
#   Logout URI / post-logout:   ${NEXT_PUBLIC_SITE_URL}/
# They must match NEXT_PUBLIC_SITE_URL exactly (scheme + host, no trailing slash).
SHOPIFY_CUSTOMER_ACCOUNT_API_URL=
SHOPIFY_CUSTOMER_ACCOUNT_CLIENT_ID=

# --- Site --------------------------------------------------------------------
# The canonical origin. Used to build the OAuth redirect/logout URIs, so it must
# equal the deployment shoppers actually sign in on (your Vercel prod URL).
NEXT_PUBLIC_SITE_URL=https://noirvault.com

# --- Email (Klaviyo) ---------------------------------------------------------
# Absent: /api/newsletter accepts the address and reports `delivered: false`.
KLAVIYO_API_KEY=
KLAVIYO_LIST_ID=

# --- Analytics ---------------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_GA_ID=


# =============================================================================
# Shopify store setup required by the live provider
# -----------------------------------------------------------------------------
# 1. Metafields, namespace `noir`, on Product — see lib/shopify/metafields.ts for
#    the authoritative key list. Type them in Admin so the Storefront API
#    returns them cleanly (number_integer for the 0–100 profile, boolean for the
#    flags, list.product_reference for similar/related/kit_products).
#
# 2. Discovery kits are Products carrying BOTH `noir.is_kit = true` AND the
#    product tag `discovery-kit`. The tag is what makes them findable and what
#    lets the main catalogue exclude them — Storefront product search cannot
#    filter on metafields.
#
# 3. Faceted filtering (rarity, season, mood, class, DNA, notes) reads product
#    TAGS, for the same reason. Mirror each `noir` facet value onto a tag — a
#    Shopify Flow rule on product publish keeps the two in sync. `noir.*` stays
#    the source of truth for what is displayed.
#
# 4. Metaobjects: `nv_homepage_section`, `nv_journal_article`,
#    `nv_journal_author`. All must have Storefront API access enabled in their
#    definition, or `metaobjects()` returns nothing.
#
# 5. Webhooks → POST /api/revalidate for: products/create|update|delete,
#    collections/create|update|delete, metaobjects/create|update|delete.
# =============================================================================
