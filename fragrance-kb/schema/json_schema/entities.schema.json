{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fragrancekb.local/schema/entities.schema.json",
  "title": "Reference entities (brand, note, accord, fragrance)",
  "$defs": {
    "brand": {
      "type": "object",
      "required": ["id", "name", "kind", "aliases"],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string"},
        "name": {"type": "string"},
        "kind": {"enum": ["original", "clone"]},
        "aliases": {"type": "array", "items": {"type": "string"}}
      }
    },
    "note": {
      "type": "object",
      "required": ["id", "name", "aliases"],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string"},
        "name": {"type": "string"},
        "aliases": {"type": "array", "items": {"type": "string"}}
      }
    },
    "accord": {
      "type": "object",
      "required": ["id", "name"],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string"},
        "name": {"type": "string"}
      }
    },
    "fragrance": {
      "type": "object",
      "required": ["id", "brandId", "brand", "name", "kind", "notes", "accords"],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string"},
        "brandId": {"type": "string"},
        "brand": {"type": "string"},
        "name": {"type": "string"},
        "kind": {"enum": ["original", "clone", "unknown"]},
        "concentration": {"type": ["string", "null"]},
        "gender": {"type": ["string", "null"]},
        "category": {"type": ["string", "null"]},
        "approxPriceUSD": {"type": ["number", "null"], "minimum": 0},
        "notes": {
          "type": "object",
          "required": ["top", "heart", "base"],
          "additionalProperties": false,
          "properties": {
            "top": {"type": "array", "items": {"type": "string"}},
            "heart": {"type": "array", "items": {"type": "string"}},
            "base": {"type": "array", "items": {"type": "string"}}
          }
        },
        "accords": {"type": "array", "items": {"type": "string"}},
        "sourceIds": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
